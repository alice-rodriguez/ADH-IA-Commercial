# === CLÉ API ANTHROPIC (obligatoire pour le filtrage IA) ===
# Créez votre clé sur : https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-votre-cle-ici

# === EMAIL MICROSOFT 365 ===
# Adresse email de l'expéditeur (votre compte M365)
EMAIL_EXPEDITEUR=votre.email@votredomaine.com
# Mot de passe d'application M365 (pas votre mot de passe habituel)
# Créez-en un dans : Paramètres M365 > Sécurité > Mots de passe d'application
EMAIL_MOT_DE_PASSE=votre_mot_de_passe_application

# === CHEMINS (optionnel — valeurs par défaut utilisées sinon) ===
DB_PATH=data/offers.db
CVS_PATH=cvs/
