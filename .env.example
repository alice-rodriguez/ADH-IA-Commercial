# === CLÉ API ANTHROPIC (obligatoire pour le filtrage IA) ===
# Créez votre clé sur : https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-votre-cle-ici

# === EMAIL — EXPÉDITEUR ===
# Adresse email Microsoft 365 qui envoie le digest
EMAIL_EXPEDITEUR=votre.email@votredomaine.com

# === AZURE AD — AUTHENTIFICATION MICROSOFT GRAPH API ===
# Ces 3 valeurs viennent de votre application enregistrée dans Azure AD.
# Portail Azure > Azure Active Directory > Inscriptions d'applications > votre app
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=votre_client_secret_ici

# === CHEMINS (optionnel — valeurs par défaut utilisées sinon) ===
DB_PATH=data/offers.db
CVS_PATH=cvs/

# === MODE TEST (optionnel) ===
# Mettre à true pour injecter 2 offres fictives et vérifier que l'email arrive
MODE_TEST=false
